{
  "expo": {
    "name": "AMR 7 PDF Tools",
    "slug": "amr7-pdf",
    "version": "1.0.2",
    "orientation": "default",
    "scheme": "amr7pdf",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#063A3D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sa.amr7.pdf",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "sa.amr7.pdf",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#063A3D"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#063A3D",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220
        }
      ],
      "expo-font",
      "expo-document-picker",
      "expo-mail-composer",
      "expo-web-browser",
      "expo-image",
      "expo-sharing",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "2e0e469e-6a9e-4cd1-a5d5-117af32dcec9"
      }
    }
  }
}
