{
  "expo": {
    "name": "آمر 7 PDF",
    "slug": "amr7-pdf",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "amr7pdf",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F8F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sa.amr7.pdf",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "sa.amr7.pdf",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F7F8F7"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F8F7",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220
        }
      ],
      "expo-font",
      "expo-document-picker",
      "expo-mail-composer"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "2e0e469e-6a9e-4cd1-a5d5-117af32dcec9"
      }
    }
  }
}